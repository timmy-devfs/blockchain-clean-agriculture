{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://bicap.io/events/retail/order-delivered",
  "title": "OrderDeliveredEvent",
  "description": "Retailer xác nhận đã nhận hàng. notification-service consume để gửi thông báo Farm Manager.",
  "type": "object",
  "required": ["eventId", "eventType", "timestamp", "version", "payload"],
  "properties": {
    "eventId":   { "type": "string", "format": "uuid" },
    "eventType": { "type": "string", "const": "ORDER_DELIVERED" },
    "timestamp": { "type": "string", "format": "date-time" },
    "version":   { "type": "string", "const": "1.0" },
    "payload": {
      "type": "object",
      "required": ["orderId", "retailerId", "farmId", "shipmentId", "deliveredAt"],
      "properties": {
        "orderId":       { "type": "string" },
        "retailerId":    { "type": "string" },
        "farmId":        { "type": "string" },
        "shipmentId":    { "type": "string" },
        "recipientName": { "type": "string" },
        "proofImageUrl": { "type": "string", "format": "uri" },
        "deliveredAt":   { "type": "string", "format": "date-time" }
      }
    }
  },
  "additionalProperties": false
}