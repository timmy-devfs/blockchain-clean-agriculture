{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "dom", "dom.iterable"],
    "types": ["node"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "paths": {
      "@bicap/types": ["./packages/types/src"],
      "@bicap/api-client": ["./packages/api-client/src"],
      "@bicap/auth": ["./packages/auth/src"],
      "@bicap/ui": ["./packages/ui/src"]
    }
  },
  "exclude": ["node_modules"]
}