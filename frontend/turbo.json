{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:admin": {
      "cache": false,
      "persistent": true
    },
    "dev:farm": {
      "cache": false,
      "persistent": true
    },
    "dev:retailer": {
      "cache": false,
      "persistent": true
    },
    "dev:shipping": {
      "cache": false,
      "persistent": true
    },
    "dev:public": {
      "cache": false,
      "persistent": true
    }
  }
}
