@baseUrl = http://localhost:8080
@token = eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiI4YTM1ZTZiNi02OGI5LTQ3MWUtODJmNC1kM2E1ZTg0YzliNWUiLCJlbWFpbCI6ImZhcm0xQGJpY2FwLmlvIiwicm9sZSI6IkZBUk1fTUFOQUdFUiIsInR5cGUiOiJBQ0NFU1MiLCJpYXQiOjE3NzU3NTY3MjEsImV4cCI6MTc3NTc1NzYyMX0.VTZhTWyUe0TV2bqt4LcTQPWsxvW9CGOiNldWo0

