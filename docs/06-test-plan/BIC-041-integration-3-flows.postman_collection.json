    {
      "name": "Luong 3 - IoT canh bao",
      "item": [
        {
          "name": "L3-01 Post sensor data vuot nguong",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Ingest sensor data status is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "var body = pm.response.json();",
                  "pm.test('alerts > 0', function () {",
                  "  pm.expect(Number(body.alerts || 0)).to.be.above(0);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-User-Id",
                "value": "{{iot_user_id}}"
              },
              {
                "key": "X-User-Role",
                "value": "FARMER"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"readings\": [\n    {\n      \"farmId\": \"{{farm_id}}\",\n      \"sensorId\": \"sensor-temp-001\",\n      \"type\": \"TEMP\",\n      \"value\": 60,\n      \"unit\": \"C\"\n    }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{iot_base_url}}/api/iot/sensors/data"
          }
        },
        {
          "name": "L3-02 Verify dashboard active alerts",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Dashboard status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var body = pm.response.json();",
                  "var active = Number(body.activeAlerts || body.alertReadings24h || 0);",
                  "pm.test('activeAlerts/alertReadings24h > 0', function () {",
                  "  pm.expect(active).to.be.above(0);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-User-Id",
                "value": "{{iot_user_id}}"
              },
              {
                "key": "X-User-Role",
                "value": "FARMER"
              }
            ],
            "url": "{{iot_base_url}}/api/iot/dashboard?farmId={{farm_id}}"
          }
        }
