{
  "info": {
    "name": "BIC-041 Integration Test - 3 Luong nghiep vu chinh",
    "_postman_id": "f7cb57dd-6200-4b82-8fe7-15406ca391d5",
    "description": "Integration tests 3 luong end-to-end bang Postman Collection + Newman.\n\nAcceptance target:\n- Luong 1: txHash != null sau polling max 30s\n- Luong 2: order.status = DELIVERED o buoc cuoi\n- Luong 3: activeAlerts/alertReadings24h > 0\n- Newman exit code = 0, co HTML report",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Luong 1 - Farm tao vu mua -> blockchain",
      "item": [
        {
          "name": "L1-01 Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var body = pm.response.json();",
                  "var accessToken = body && body.data ? body.data.accessToken : null;",
                  "var user = body && body.data ? body.data.user : null;",
                  "var userId = user ? (user.id || user.userId || '') : '';",
                  "",
                  "if (accessToken) { pm.environment.set('identity_access_token', accessToken); }",
                  "if (userId) { pm.environment.set('farm_user_id', userId); }",
                  "",
                  "pm.test('Login response has token', function () {",
                  "  pm.expect(accessToken, 'missing accessToken').to.be.a('string').and.not.empty;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{identity_email}}\",\n  \"password\": \"{{identity_password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{identity_base_url}}/api/auth/login"
          }
        },
        {
          "name": "L1-02 Create season",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Create season status is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "var body = pm.response.json();",
                  "var seasonId = body.id || body.data && body.data.id;",
                  "if (seasonId) { pm.environment.set('season_id', seasonId); }",
                  "",
                  "pm.test('Season id is captured', function () {",
                  "  pm.expect(pm.environment.get('season_id')).to.be.a('string').and.not.empty;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-User-Id",
                "value": "{{farm_user_id}}"
              },
              {
                "key": "X-User-Role",
                "value": "FARMER"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"farmId\": \"{{farm_id}}\",\n  \"cropType\": \"Rice\",\n  \"startDate\": \"2026-04-21\",\n  \"estimatedEndDate\": \"2026-08-21\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{farm_base_url}}/api/farm/seasons"
          }
        },
        {
          "name": "L1-03 Mark HARVESTED",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Mark harvested status is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-User-Id",
                "value": "{{farm_user_id}}"
              },
              {
                "key": "X-User-Role",
                "value": "FARMER"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"HARVESTED\",\n  \"note\": \"Ready for blockchain export\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{farm_base_url}}/api/farm/seasons/{{season_id}}/updates"
          }
        },
        {
          "name": "L1-04 Export season",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Export season status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.collectionVariables.set('poll_attempt', '0');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-User-Id",
                "value": "{{farm_user_id}}"
              },
              {
                "key": "X-User-Role",
                "value": "FARMER"
              }
            ],
            "url": "{{farm_base_url}}/api/farm/seasons/{{season_id}}/export"
          }
        },
        {
          "name": "L1-05 Poll txHash (max 30s)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Poll txHash status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var body = pm.response.json();",
                  "var txHash = body.txHash || (body.data && body.data.txHash) || (body.season && body.season.txHash) || (body.blockchain && body.blockchain.txHash);",
                  "",
                  "if (txHash) {",
                  "  pm.environment.set('season_tx_hash', txHash);",
                  "  pm.test('txHash is not null', function () {",
                  "    pm.expect(txHash).to.be.a('string').and.not.empty;",
                  "  });",
                  "  postman.setNextRequest(null);",
                  "} else {",
                  "  var attempt = Number(pm.collectionVariables.get('poll_attempt') || '0') + 1;",
                  "  pm.collectionVariables.set('poll_attempt', String(attempt));",
                  "  var maxAttempts = Number(pm.environment.get('max_poll_attempts') || '6');",
                  "  if (attempt < maxAttempts) {",
                  "    postman.setNextRequest('L1-05 Poll txHash (max 30s)');",
                  "  } else {",
                  "    pm.expect.fail('txHash is still null after max polling attempts (~30s)');",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-User-Id",
                "value": "{{farm_user_id}}"
              },
              {
                "key": "X-User-Role",
                "value": "FARMER"
              }
            ],
            "url": "{{farm_base_url}}/api/farm/seasons/{{season_id}}"
          }
        }
      ]
    },
    {
