# Retailer Service — Environment Variables Template
# Copy thành `.env` tại thư mục `services/retailer-service/`.
# Không commit file `.env` lên Git.

NODE_ENV=development
PORT=8083

# MongoDB
DATABASE_URL="mongodb://localhost:27017/retailer_db"

KAFKA_CLIENT_ID=retailer-service
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=retailer-service-group

INIT_INFRA_ON_BOOT=false
REDIS_URL=redis://localhost:6379

FARM_SERVICE_BASE_URL=http://localhost:8082
BLOCKCHAIN_SERVICE_BASE_URL=http://localhost:8090

JWT_SECRET=retailer-secret

