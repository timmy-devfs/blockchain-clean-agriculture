@shipmentId = 1
@driverId = 1
@vehicleId = 1

# ═══════════════════════════════════════════════════════════════════
# QUAN TRỌNG: shipping-service là Java Spring Boot.
# Các endpoint bên dưới được suy luận từ Entity classes (Shipment, Driver, Vehicle)
# và pattern chuẩn của Spring MVC REST.
# Nếu có Controller cụ thể, hãy kiểm tra và điều chỉnh đường dẫn cho phù hợp.
# ═══════════════════════════════════════════════════════════════════


# ═══════════════════════════════════════════════════════════════════
# MODULE 1: DRIVERS (Quản lý tài xế)
# ═══════════════════════════════════════════════════════════════════

###
# TC-SH-D01 | HAPPY PATH | Tạo tài xế mới
# Mô tả   : Thêm tài xế vào hệ thống với đầy đủ thông tin
# Entity  : Driver — fullName, phone, licenseNo (required), licenseClass, isActive
# Expected: HTTP 201 Created — driver object với id tự tăng
POST {{baseUrl}}/api/shipping/drivers
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "fullName": "Nguyễn Văn Tài",
  "phone": "0912345678",
  "licenseNo": "079123456789",
  "licenseClass": "C",
  "isActive": true
}

###
# TC-SH-D02 | SAD PATH | Tạo tài xế — Thiếu fullName (required)
# Expected: HTTP 400 Bad Request — validation error
POST {{baseUrl}}/api/shipping/drivers
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "phone": "0912345678",
  "licenseNo": "079123456789"
}

###
# TC-SH-D03 | HAPPY PATH | Lấy danh sách tài xế
# Expected: HTTP 200 OK — array driver objects
GET {{baseUrl}}/api/shipping/drivers
Authorization: Bearer {{token}}

###
# TC-SH-D04 | HAPPY PATH | Lấy chi tiết tài xế theo ID
# Expected: HTTP 200 OK — driver object
GET {{baseUrl}}/api/shipping/drivers/{{driverId}}
Authorization: Bearer {{token}}

###
# TC-SH-D05 | SAD PATH | Lấy tài xế — ID không tồn tại
# Expected: HTTP 404 Not Found
GET {{baseUrl}}/api/shipping/drivers/99999
Authorization: Bearer {{token}}

###
# TC-SH-D06 | HAPPY PATH | Cập nhật thông tin tài xế
# Mô tả   : Vô hiệu hóa tài xế (isActive = false)
# Expected: HTTP 200 OK — driver object đã cập nhật
PUT {{baseUrl}}/api/shipping/drivers/{{driverId}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "fullName": "Nguyễn Văn Tài",
  "phone": "0912345678",
  "licenseNo": "079123456789",
  "licenseClass": "C",
  "isActive": false
}

###
# TC-SH-D07 | HAPPY PATH | Xóa tài xế
# Expected: HTTP 204 No Content hoặc HTTP 200 OK
DELETE {{baseUrl}}/api/shipping/drivers/{{driverId}}
Authorization: Bearer {{token}}

###
# TC-SH-D08 | SAD PATH | Xóa tài xế — ID không tồn tại
# Expected: HTTP 404 Not Found
DELETE {{baseUrl}}/api/shipping/drivers/99999
Authorization: Bearer {{token}}


# ═══════════════════════════════════════════════════════════════════
# MODULE 2: VEHICLES (Quản lý phương tiện)
# VehicleType enum: TRUCK | VAN | MOTORBIKE | REFRIGERATED_TRUCK
# ═══════════════════════════════════════════════════════════════════

###
# TC-SH-V01 | HAPPY PATH | Tạo xe mới
# Entity  : Vehicle — licensePlate, type (VehicleType), capacity, isActive
# Expected: HTTP 201 Created — vehicle object với id tự tăng
POST {{baseUrl}}/api/shipping/vehicles
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "licensePlate": "51F-12345",
  "type": "REFRIGERATED_TRUCK",
  "capacity": 2000.0,
  "isActive": true
}

###
# TC-SH-V02 | SAD PATH | Tạo xe — type enum không hợp lệ
# Expected: HTTP 400 Bad Request — type must be TRUCK | VAN | MOTORBIKE | REFRIGERATED_TRUCK
POST {{baseUrl}}/api/shipping/vehicles
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "licensePlate": "51G-99999",
  "type": "BICYCLE",
  "capacity": 50.0,
  "isActive": true
}

###
# TC-SH-V03 | SAD PATH | Tạo xe — Thiếu licensePlate
# Expected: HTTP 400 Bad Request — validation error
POST {{baseUrl}}/api/shipping/vehicles
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "type": "VAN",
  "capacity": 800.0
}

###
# TC-SH-V04 | HAPPY PATH | Lấy danh sách xe
# Expected: HTTP 200 OK — array vehicle objects
GET {{baseUrl}}/api/shipping/vehicles
Authorization: Bearer {{token}}

###
# TC-SH-V05 | HAPPY PATH | Lấy chi tiết xe theo ID
# Expected: HTTP 200 OK — vehicle object
GET {{baseUrl}}/api/shipping/vehicles/{{vehicleId}}
Authorization: Bearer {{token}}

###
# TC-SH-V06 | SAD PATH | Lấy xe — ID không tồn tại
# Expected: HTTP 404 Not Found
GET {{baseUrl}}/api/shipping/vehicles/99999
Authorization: Bearer {{token}}

###
# TC-SH-V07 | HAPPY PATH | Cập nhật xe (đánh dấu xe không còn hoạt động)
# Expected: HTTP 200 OK — vehicle object updated
PUT {{baseUrl}}/api/shipping/vehicles/{{vehicleId}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "licensePlate": "51F-12345",
  "type": "REFRIGERATED_TRUCK",
  "capacity": 2000.0,
  "isActive": false
}

###
# TC-SH-V08 | HAPPY PATH | Xóa xe
# Expected: HTTP 204 No Content hoặc HTTP 200 OK
DELETE {{baseUrl}}/api/shipping/vehicles/{{vehicleId}}
Authorization: Bearer {{token}}


# ═══════════════════════════════════════════════════════════════════
# MODULE 3: SHIPMENTS (Quản lý chuyến giao hàng)
# ShipmentStatus: CREATED → ASSIGNED → PICKED_UP → IN_TRANSIT →
#                 DELAYED | DELIVERED | CANCELLED
# ═══════════════════════════════════════════════════════════════════

###
# TC-SH-S01 | HAPPY PATH | Tạo chuyến giao hàng mới
# Mô tả   : Tạo shipment sau khi order được xác nhận (Kafka event từ retailer-service)
# Entity  : Shipment — orderId, farmId, retailerId (required), driverId, vehicleId (phân công sau),
#           pickupAddress, deliveryAddress, scheduledDate (optional, dùng khi có driver)
# Expected: HTTP 201 Created — shipment object với status=CREATED
POST {{baseUrl}}/api/shipping/shipments
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "orderId": 1001,
  "farmId": 5,
  "retailerId": 3,
  "pickupAddress": "Trại Dâu Xanh — 123 Đường Hoa Hồng, Đà Lạt, Lâm Đồng",
  "deliveryAddress": "45 Đường Láng Hạ, Quận Đống Đa, Hà Nội",
  "scheduledDate": "2025-07-01"
}

###
# TC-SH-S02 | SAD PATH | Tạo shipment — Thiếu orderId (required)
# Expected: HTTP 400 Bad Request — validation error
POST {{baseUrl}}/api/shipping/shipments
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "farmId": 5,
  "retailerId": 3,
  "pickupAddress": "Đà Lạt",
  "deliveryAddress": "Hà Nội"
}

###
# TC-SH-S03 | HAPPY PATH | Lấy danh sách shipments
# Expected: HTTP 200 OK — array shipment objects
GET {{baseUrl}}/api/shipping/shipments
Authorization: Bearer {{token}}

###
# TC-SH-S04 | HAPPY PATH | Lấy chi tiết shipment theo ID
# Expected: HTTP 200 OK — shipment object (bao gồm status history nếu có)
GET {{baseUrl}}/api/shipping/shipments/{{shipmentId}}
Authorization: Bearer {{token}}

###
# TC-SH-S05 | SAD PATH | Lấy shipment — ID không tồn tại
# Expected: HTTP 404 Not Found
GET {{baseUrl}}/api/shipping/shipments/99999
Authorization: Bearer {{token}}

###
# TC-SH-S06 | HAPPY PATH | Phân công tài xế và xe cho shipment (CREATED → ASSIGNED)
# Mô tả   : Dispatcher gắn driverId và vehicleId → status chuyển sang ASSIGNED
# Expected: HTTP 200 OK — shipment với status=ASSIGNED, driverId và vehicleId được gán
PUT {{baseUrl}}/api/shipping/shipments/{{shipmentId}}/assign
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "driverId": {{driverId}},
  "vehicleId": {{vehicleId}}
}

###
# TC-SH-S07 | SAD PATH | Phân công — driverId không tồn tại
# Expected: HTTP 404 Not Found — Driver not found
PUT {{baseUrl}}/api/shipping/shipments/{{shipmentId}}/assign
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "driverId": 99999,
  "vehicleId": {{vehicleId}}
}

###
# TC-SH-S08 | HAPPY PATH | Cập nhật trạng thái shipment
# Mô tả   : Tài xế cập nhật trạng thái realtime (PICKED_UP, IN_TRANSIT, DELIVERED...)
# ShipmentStatus workflow: CREATED → ASSIGNED → PICKED_UP → IN_TRANSIT → DELIVERED | DELAYED | CANCELLED
# Expected: HTTP 200 OK — shipment object với status mới, Kafka event published
PATCH {{baseUrl}}/api/shipping/shipments/{{shipmentId}}/status
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "status": "PICKED_UP",
  "note": "Đã đến kho lấy hàng lúc 08:30"
}

###
# TC-SH-S09 | HAPPY PATH | Cập nhật trạng thái → IN_TRANSIT
# Expected: HTTP 200 OK — status=IN_TRANSIT, Kafka event ORDER_UPDATED published
PATCH {{baseUrl}}/api/shipping/shipments/{{shipmentId}}/status
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "status": "IN_TRANSIT",
  "note": "Xe đang trên đường cao tốc Bắc-Nam"
}

###
# TC-SH-S10 | HAPPY PATH | Xác nhận giao hàng thành công → DELIVERED
# Expected: HTTP 200 OK — status=DELIVERED, Kafka event ORDER_DELIVERED triggered
PATCH {{baseUrl}}/api/shipping/shipments/{{shipmentId}}/status
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "status": "DELIVERED",
  "note": "Giao hàng thành công lúc 15:20, người nhận: Nguyễn Thị Mai"
}

###
# TC-SH-S11 | SAD PATH | Cập nhật status — Giá trị enum không hợp lệ
# Expected: HTTP 400 Bad Request — status must be one of ShipmentStatus values
PATCH {{baseUrl}}/api/shipping/shipments/{{shipmentId}}/status
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "status": "DONE"
}

###
# TC-SH-S12 | HAPPY PATH | Hủy shipment
# Mô tả   : Hủy chuyến hàng (chỉ khi chưa PICKED_UP)
# Expected: HTTP 200 OK — shipment với status=CANCELLED
PATCH {{baseUrl}}/api/shipping/shipments/{{shipmentId}}/status
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "status": "CANCELLED",
  "note": "Hủy theo yêu cầu của farmer do hết hàng"
}


# ═══════════════════════════════════════════════════════════════════
# MODULE 4: SHIPPING REPORTS
# ═══════════════════════════════════════════════════════════════════

###
# TC-SH-R01 | HAPPY PATH | Lấy báo cáo giao hàng
# Mô tả   : Xem báo cáo tổng quan về tình trạng giao hàng trong kỳ
# Expected: HTTP 200 OK — ShippingReport object
GET {{baseUrl}}/api/shipping/reports
Authorization: Bearer {{token}}

###
# TC-SH-R02 | HAPPY PATH | Health check shipping-service
# Mô tả   : Kiểm tra service có sống không (không cần auth)
# Expected: HTTP 200 OK — { status: "UP" } hoặc Spring Actuator health response
GET {{baseUrl}}/api/shipping/actuator/health
