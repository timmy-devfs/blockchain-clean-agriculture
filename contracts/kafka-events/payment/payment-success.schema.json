{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://bicap.io/events/payment/payment-success",
  "title": "PaymentSuccessEvent",
  "description": "Payment gateway callback thành công, HMAC verified. retailer-service consume để update status = PLACED.",
  "type": "object",
  "required": ["eventId", "eventType", "timestamp", "version", "payload"],
  "properties": {
    "eventId":   { "type": "string", "format": "uuid" },
    "eventType": { "type": "string", "const": "PAYMENT_SUCCESS" },
    "timestamp": { "type": "string", "format": "date-time" },
    "version":   { "type": "string", "const": "1.0" },
    "payload": {
      "type": "object",
      "required": ["paymentId", "orderId", "payerId", "amount", "gateway", "transactionId", "type", "paidAt"],
      "properties": {
        "paymentId":     { "type": "string" },
        "orderId":       { "type": "string" },
        "payerId":       { "type": "string" },
        "payerRole":     { "type": "string", "enum": ["RETAILER", "FARM_MANAGER"] },
        "amount":        { "type": "number" },
        "gateway":       { "type": "string", "enum": ["VNPAY", "MOMO"] },
        "transactionId": { "type": "string", "description": "Mã giao dịch từ gateway" },
        "type":          { "type": "string", "enum": ["DEPOSIT", "PACKAGE", "FULL_PAYMENT"] },
        "paidAt":        { "type": "string", "format": "date-time" }
      }
    }
  },
  "additionalProperties": false
}