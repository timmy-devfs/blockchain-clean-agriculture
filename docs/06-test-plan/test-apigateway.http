# ═══════════════════════════════════════════════════════════════════
# MODULE 0: IDENTITY SERVICE (Auth)
# Gateway Route: /api/auth/** → http://localhost:8081
# ═══════════════════════════════════════════════════════════════════

###
# TC-GW-AUTH01 | HAPPY PATH | Đăng ký tài khoản mới
# Expected: HTTP 201 Created — user object (không có password trong response)
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
  "username": "farmer_test_01",
  "email": "farmer01@bicap.io",
  "password": "SecureP@ss2025!",
  "role": "FARMER"
}

###
# TC-GW-AUTH02 | HAPPY PATH | Đăng nhập — Lấy JWT token
# Mô tả   : Đăng nhập thành công → copy accessToken vào @token ở mỗi file
# Expected: HTTP 200 OK — { accessToken, refreshToken, expiresIn }
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "farmer_test_01",
  "password": "SecureP@ss2025!"
}

###
# TC-GW-AUTH03 | HAPPY PATH | Đăng nhập với tài khoản ADMIN
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "admin_bicap",
  "password": "AdminP@ss2025!"
}

###
# TC-GW-AUTH04 | SAD PATH | Đăng nhập — Sai mật khẩu
# Expected: HTTP 401 Unauthorized hoặc 400 (tùy implementation)
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "farmer_test_01",
  "password": "wrong-password"
}

###
# TC-GW-AUTH05 | HAPPY PATH | Introspect token (kiểm tra token còn hiệu lực)
# Path được cấu hình tại: identity.service.introspect-path=/api/auth/introspect
# Expected: HTTP 200 OK — { valid: true, userId, userRole, ... }
POST {{baseUrl}}/api/auth/introspect
Content-Type: application/json

{
  "token": "{{token}}"
}

###
# TC-GW-AUTH06 | HAPPY PATH | Refresh access token
# Expected: HTTP 200 OK — { accessToken mới }
POST {{baseUrl}}/api/auth/refresh
Content-Type: application/json

{
  "refreshToken": "REPLACE_WITH_REFRESH_TOKEN"
}


# ═══════════════════════════════════════════════════════════════════
# MODULE: GATEWAY ROUTING SMOKE TEST
# Kiểm tra từng route prefix đã được cấu hình trong application.yml
# ═══════════════════════════════════════════════════════════════════

###
# TC-GW-ROUTE01 | SMOKE TEST | Farm Service Health
# Expected: HTTP 200 OK — farm-service đang running
GET {{baseUrl}}/api/farm/health

###
# TC-GW-ROUTE02 | SMOKE TEST | Retailer Service Marketplace (public endpoint)
# Expected: HTTP 200 OK — marketplace products (có thể là empty array)
GET {{baseUrl}}/api/retail/marketplace/products

###
# TC-GW-ROUTE03 | SMOKE TEST | Gateway Actuator Health
# Expected: HTTP 200 OK — { status: "UP", components: {...} }
GET {{baseUrl}}/actuator/health

###
# TC-GW-ROUTE04 | SMOKE TEST | Gateway Routes (xem tất cả routes đã cấu hình)
# Expected: HTTP 200 OK — array route definitions
GET {{baseUrl}}/actuator/gateway/routes

###
# TC-GW-ROUTE05 | SAD PATH | Gọi path không được route trong gateway
# Expected: HTTP 404 Not Found (gateway không có route khớp)
GET {{baseUrl}}/api/unknown-service/endpoint


# ═══════════════════════════════════════════════════════════════════
# MODULE: SECURITY TEST
# ═══════════════════════════════════════════════════════════════════

###
# TC-GW-SEC01 | SAD PATH | Gọi protected API không có token
# Mô tả   : Gateway AuthFilter phải intercept và trả về 401 trước khi forward
# Expected: HTTP 401 Unauthorized
GET {{baseUrl}}/api/farm/farms

###
# TC-GW-SEC02 | SAD PATH | Gọi protected API với token hết hạn / sai chữ ký
# Expected: HTTP 401 Unauthorized — token introspect failed
GET {{baseUrl}}/api/farm/farms
Authorization: Bearer eyJhbGciOiJIUzI1NiJ9.EXPIRED_OR_INVALID.TOKEN

###
# TC-GW-SEC03 | SAD PATH | Rate Limit Test — Gọi nhiều request trong 1 phút (anonymous)
# Mô tả   : Cấu hình: anonymous-per-minute: 100, authenticated-per-minute: 500
# Expected: Sau 101 request/1 phút không auth → HTTP 429 Too Many Requests
# (Hãy dùng script hoặc k6/JMeter để test rate limit thực sự)
GET {{baseUrl}}/api/retail/marketplace/products


# ═══════════════════════════════════════════════════════════════════
# MODULE: CIRCUIT BREAKER TEST
# ═══════════════════════════════════════════════════════════════════

###
# TC-GW-CB01 | Circuit Breaker | Gọi service đang DOWN (fallback)
# Mô tả   : Khi farm-service DOWN, gateway phải trả về fallback response
#           thay vì lỗi 502/503 lan ra client
# Cách test: Tắt farm-service, sau đó gọi API
# Expected: HTTP 503 Service Unavailable (từ fallback) với message rõ ràng
# (Hoặc response fallback tùy custom FallbackController)
GET {{baseUrl}}/api/farm/farms
Authorization: Bearer {{token}}
