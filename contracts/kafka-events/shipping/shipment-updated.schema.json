{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://bicap.io/events/shipping/shipment-updated",
  "title": "ShipmentUpdatedEvent",
  "description": "Mỗi lần Driver cập nhật trạng thái chuyến hàng. notification-service consume để push thông báo.",
  "type": "object",
  "required": ["eventId", "eventType", "timestamp", "version", "payload"],
  "properties": {
    "eventId":   { "type": "string", "format": "uuid" },
    "eventType": { "type": "string", "const": "SHIPMENT_UPDATED" },
    "timestamp": { "type": "string", "format": "date-time" },
    "version":   { "type": "string", "const": "1.0" },
    "payload": {
      "type": "object",
      "required": ["shipmentId", "orderId", "driverId", "status", "updatedAt"],
      "properties": {
        "shipmentId":  { "type": "string" },
        "orderId":     { "type": "string" },
        "farmId":      { "type": "string" },
        "retailerId":  { "type": "string" },
        "driverId":    { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["ASSIGNED","PICKED_UP","IN_TRANSIT","DELAYED","DELIVERED","FAILED"]
        },
        "location":    { "type": "string", "description": "Địa điểm hiện tại (optional)" },
        "note":        { "type": "string" },
        "imageUrl":    { "type": "string", "format": "uri" },
        "updatedAt":   { "type": "string", "format": "date-time" }
      }
    }
  },
  "additionalProperties": false
}