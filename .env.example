# ════════════════════════════════════════════════════════════
# BICAP SYSTEM — Environment Variables Template
# Copy file này thành .env và điền giá trị thực
# KHÔNG commit file .env lên GitHub
# ════════════════════════════════════════════════════════════

# ── Infrastructure ──────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID_PREFIX=bicap

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── SQL Server (dùng chung cho dev, prod mỗi service 1 DB) ──
DB_HOST=localhost
DB_PORT=1433
DB_USERNAME=sa
DB_PASSWORD=YourStrong!Passw0rd

# ── api-gateway (port 8080) ─────────────────────────────────
GATEWAY_PORT=8080
GATEWAY_JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ── identity-service (port 8081) ───────────────────────────
IDENTITY_PORT=8081
IDENTITY_DB_NAME=identity_db
IDENTITY_JWT_SECRET=your-super-secret-jwt-key-change-in-production
IDENTITY_JWT_ACCESS_EXPIRY=900000
IDENTITY_JWT_REFRESH_EXPIRY=604800000

# ── farm-service (port 8082) ────────────────────────────────
FARM_PORT=8082
FARM_DB_NAME=farm_db
FARM_REDIS_TTL=300

# ── retailer-service (port 8083) ────────────────────────────
RETAILER_PORT=8083
RETAILER_DB_NAME=retailer_db

# ── shipping-service (port 8084) ────────────────────────────
SHIPPING_PORT=8084
SHIPPING_DB_NAME=shipping_db

# ── notification-service (port 8085) ───────────────────────
NOTIFICATION_PORT=8085
NOTIFICATION_DB_NAME=notification_db
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-client-email

# ── payment-service (port 8086) ─────────────────────────────
PAYMENT_PORT=8086
PAYMENT_DB_NAME=payment_db
VNPAY_TMN_CODE=your-vnpay-tmn-code
VNPAY_HASH_SECRET=your-vnpay-hash-secret
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:3002/payment/callback
MOMO_PARTNER_CODE=your-momo-partner-code
MOMO_ACCESS_KEY=your-momo-access-key
MOMO_SECRET_KEY=your-momo-secret-key

# ── iot-service (port 8087) ─────────────────────────────────
IOT_PORT=8087
IOT_DB_NAME=iot_db
IOT_REDIS_SERIES_MAX=288

# ── report-service (port 8088) ──────────────────────────────
REPORT_PORT=8088
REPORT_DB_NAME=report_db

# ── guest-service (port 8089) ───────────────────────────────
GUEST_PORT=8089
GUEST_DB_NAME=guest_db
GUEST_REDIS_TTL=600

# ── blockchain-service (port 8090 — NodeJS) ─────────────────
BLOCKCHAIN_PORT=8090
VECHAIN_NODE_URL=https://testnet.veblocks.net
VECHAIN_MNEMONIC=your-twelve-word-mnemonic-phrase-here
VECHAIN_NETWORK=test
CONTRACT_FARM_TRACE_ADDRESS=
CONTRACT_PRODUCT_CERT_ADDRESS=

# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_GATEWAY_URL=http://localhost:8080
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your-google-maps-api-key
NEXT_PUBLIC_APP_ENV=development

# ── NiFi ────────────────────────────────────────────────────
NIFI_PORT=8443
NIFI_USERNAME=admin
NIFI_PASSWORD=your-nifi-password